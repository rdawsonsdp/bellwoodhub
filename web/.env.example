# ── Village Knowledge AI Hub — environment ──
# Copy to .env.local and fill in. .env.local is gitignored; never commit secrets.

# Supabase Postgres connection (the same store the Python pipeline loads).
# Use the Session pooler URI from Supabase → Project Settings → Database.
#   postgresql://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# OpenAI — embeddings (text-embedding-3-small) + grounded answers (gpt-4o-mini).
OPENAI_API_KEY=

# Optional model overrides (defaults shown).
# EMBED_MODEL=text-embedding-3-small
# ANSWER_MODEL=gpt-4o-mini

# Optional: shared secret for the MCP endpoint (?k=<secret> or Bearer). Unset = open.
MCP_SECRET=
