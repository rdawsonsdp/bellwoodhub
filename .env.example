# ── Bellwood Mayor's Office Email RAG POC — environment template ──
# Copy to .env and fill in. .env is gitignored.

# OpenAI API key (used only for embeddings: text-embedding-3-small)
OPENAI_API_KEY=sk-proj-...

# Supabase project ref (the "emailagent" project)
SUPABASE_PROJECT_REF=rqbkxoniqmuyvvpjbegu

# Direct Postgres connection string (Supabase dashboard → Settings → Database → URI).
# Required by load_embed.py, extract_entities.py, and query.py.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.rqbkxoniqmuyvvpjbegu.supabase.co:5432/postgres

# ── AI Chief of Staff (canonical pipeline) ──────────────────────────────────
# Voyage embeddings (canonical.chunks is vector(1024)); Voyage is under MongoDB.
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-4-large
VOYAGE_DIM=1024
# Anthropic — classification (Haiku) + synthesis/drafting (Sonnet); Opus gated by eval.
ANTHROPIC_API_KEY=sk-ant-...
HAIKU_MODEL=claude-haiku-4-5
SONNET_MODEL=claude-sonnet-4-6
OPUS_MODEL=claude-opus-4-8
