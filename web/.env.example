# ── Village Knowledge AI Hub — environment ──
# Copy to .env.local and fill in. .env.local is gitignored; never commit secrets.

# Supabase Postgres connection (the same store the Python pipeline loads).
# Use the Session pooler URI from Supabase → Project Settings → Database.
#   postgresql://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# OpenAI — embeddings (text-embedding-3-small) + grounded answers (gpt-4o-mini).
OPENAI_API_KEY=

# Optional model overrides (defaults shown).
# ANSWER_MODEL=gpt-4o-mini

# ── AI Chief of Staff (canonical backend) ──────────────────────────────────
# Flip the retrieval backend: poc (default, flat store) | canonical (graph planner).
RETRIEVAL_BACKEND=poc
# Voyage embeddings for the canonical store (vector(1024)). Used when RETRIEVAL_BACKEND=canonical.
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-4-large
# VOYAGE_DIM=1024
# Anthropic — Claude synthesis/drafting (Sonnet) + classification (Haiku); Opus gated by eval.
ANTHROPIC_API_KEY=
# HAIKU_MODEL=claude-haiku-4-5
# SONNET_MODEL=claude-sonnet-4-6
# OPUS_MODEL=claude-opus-4-8

# Optional: shared secret for the MCP endpoint (?k=<secret> or Bearer). Unset = open.
MCP_SECRET=

# Vercel Cron auth (weekly /api/cron/refresh). Set the same value as a Vercel env var.
CRON_SECRET=
